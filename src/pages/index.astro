---
import TrustLayout from "../layouts/TrustLayout.astro";
import { trust } from "../lib/trust";
import { indexSections, type SectionKey } from "../lib/sitemap";

const publicDocs = trust.documents.filter((d) => d.access === "public").length;
const requestDocs = trust.documents.filter((d) => d.access === "request").length;
const lastChange = trust.subprocessorChangelog[0]?.date ?? trust.meta.updatedAt;

// Which rows appear (and in what order) is the registry's call — only
// `published` sections with an indexTitle show here. The right-hand meta is
// computed from live trust data, keyed by section.
const rowMeta: Partial<Record<SectionKey, string>> = {
  how: `updated ${trust.meta.updatedAt}`,
  subs: `changed ${lastChange}`,
  docs: `${publicDocs} public · ${requestDocs} on request`,
  assurance: "our SOC 2 position",
  audit: "SOC 2 · ISO 27001 · HECVAT",
};

const indexRows = indexSections.map((s) => ({
  href: s.href,
  title: s.indexTitle!,
  meta: rowMeta[s.key] ?? "",
}));
---

<TrustLayout
  title="Overview"
  description="What Onetime Secret does to earn your trust: how secrets are handled, who our subprocessors are, which documents we publish, and how to cite us in your audit."
  active="overview"
>
  <div class="page home" style="max-width: 668px;">
    <h1 style="font-size: 46px; line-height: 1.18; margin-bottom: 34px;">
      Trust,<br />earned in the open.
    </h1>
    <div class="prose" style="font-size: 17.5px; line-height: 1.75;">
      <p>
        If a SOC 2 or ISO 27001 report is a firm requirement, we won't be a fit, and we'd rather
        tell you that now than after a review cycle.
      </p>
      <p>
        We don't hold either report today. Onetime Secret is a one-person company — when I say "we",
        I mean me — and while the cost of SOC 2 or ISO 27001 reporting is manageable, the
        operational capacity to sustain it isn't there yet. What we offer instead you can check
        without taking our word for it: the code is open source, this record is versioned in public,
        and the product is built so that trust depends as little as possible on us — secrets are
        encrypted, read once, and destroyed.
      </p>
      <p>
        This site is our security report, written by us. It covers how secrets and other data are
        handled, who our subprocessors are, which documents we can give you, and exactly how to cite
        us in your own SOC 2 or ISO 27001 reports and audits.
      </p>
      <p>
        If you need something that isn't here, email us. A person answers, usually the person who
        wrote the code, within five business days.
      </p>
    </div>

    <div class="rule-list" style="margin-top: 44px; padding-top: 10px;">
      {
        indexRows.map((row) => (
          <a class="rule-row" href={row.href} style="padding: 15px 0;">
            <span class="row-title">{row.title}</span>
            <span class="row-meta">{row.meta}</span>
          </a>
        ))
      }
    </div>

    <p
      style="font: 400 13px/1.6 var(--sans); color: var(--faint); margin-top: 52px; text-align: center;"
    >
      This page is a public git repository ·
      <a href="https://github.com/onetimesecret/site-policy">view source &amp; history</a> ·
      <a href="/.well-known/security.txt">security.txt</a> ·
      <a href={trust.meta.contacts.pgp}>PGP</a> ·
      <a href="/trust.yaml">trust.yaml</a>
    </p>
  </div>
</TrustLayout>
