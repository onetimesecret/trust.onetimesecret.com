---
import { trust } from "../lib/trust";
import type { RegionCode, Subprocessor } from "../lib/trust-config";

// The per-region architecture diagram: internet at the top, then the two
// ingress paths — the regional service domain (Cloudflare) and customer
// custom domains (Approximated, never Cloudflare) — converging on the
// region's hosting, with backups, email, and payments alongside. Every
// node is a service row from trust.yaml, so the diagram mirrors DPA
// Schedule A by construction.

type Service = Subprocessor["services"][number];
type Slot = { s: Subprocessor; r: Service };

// The diagram is "what a secret here can touch" — the customer secret flow.
// Two kinds of provider are kept out of it:
//   • standby (whole-vendor or per-service) — process no customer data yet;
//   • operational — run our own operations, not the secret flow (Proton Mail
//     support/company email, internal infra) even when active.
// Both live in the "used internally" section of the register instead.
// Transitioning services stay on the diagram with the dashed border.
const services: Slot[] = trust.subprocessors
  .filter((s) => s.engagement === "active" && !s.operational)
  .flatMap((s) => s.services.filter((r) => r.status !== "standby").map((r) => ({ s, r })));

const inRegion = ({ r }: Slot, code: RegionCode) =>
  r.regions === "global" || r.regions.includes(code);

// Ingress identification is by provider: Cloudflare's two services (DNS,
// edge proxy) are the service-domain path; Approximated is the
// custom-domain path. BunnyCDN's network service serves only the public
// marketing/docs sites — no customer data path — so it stays off the
// diagram and appears in the full list below.
const isDns = ({ s, r }: Slot) => s.shortName === "Cloudflare" && r.category === "infrastructure";
const isProxy = ({ s, r }: Slot) => s.shortName === "Cloudflare" && r.category === "network";
const isCustomIngress = ({ s }: Slot) => s.shortName === "Approximated";

const nodeSub = (r: Service) =>
  `${r.short} · ${r.tiers === "All" ? r.location : /tiers?$/i.test(r.tiers) ? r.tiers : `${r.tiers} only`}`;

const panels = trust.regions.map((region) => {
  const here = services.filter((slot) => inRegion(slot, region.code));
  return {
    region,
    serviceIngress: here.filter((x) => isDns(x) || isProxy(x)),
    customIngress: here.filter(isCustomIngress),
    hosting: here.filter((slot) => slot.r.category === "infrastructure" && !isDns(slot)),
    backups: here.filter(({ r }) => r.category === "backup"),
    email: here.filter(({ r }) => r.category === "email"),
    payments: here.filter(({ r }) => r.category === "payments"),
  };
});
---

<div class="arch" data-arch>
  <div class="arch-box dashed center">
    <div class="arch-box-label">The internet</div>
    <div class="arch-note">People sharing and reading secrets</div>
  </div>

  <!-- One arrow off the internet fanning out to every region: stem →
       rail across the tab centers (measured into --tab-x-*), one
       arrowhead drop per tab. -->
  <div class="arch-branch" aria-hidden="true">
    <i class="branch-stem"></i>
    <i class="branch-rail"></i>
    {trust.regions.map((_, i) => <i class="branch-drop" style={`--x: var(--tab-x-${i}, 50%)`} />)}
  </div>

  <!-- The tabs sit at the fork: the internet above is region-agnostic;
       everything below is determined by the selected region. -->
  <div class="arch-tabs" role="tablist" aria-label="Choose a region">
    {
      trust.regions.map((region, i) => (
        <button
          type="button"
          role="tab"
          id={`arch-tab-${region.code}`}
          aria-controls={`arch-${region.code}`}
          aria-selected={i === 0 ? "true" : "false"}
          data-region={region.code}
        >
          {region.code.toUpperCase()}
        </button>
      ))
    }
  </div>

  {
    panels.map((p, i) => (
      <div
        class="arch-panel"
        id={`arch-${p.region.code}`}
        role="tabpanel"
        aria-labelledby={`arch-tab-${p.region.code}`}
        data-region={p.region.code}
        hidden={i !== 0}
      >
        <div class="arch-cols two">
          <!-- Fork: stem drops from the selected tab (x tracked via
               --fork-x), rail spans the column centers, one arrowhead
               lands on each ingress path. -->
          <div class="arch-fork" aria-hidden="true">
            <i class="fork-stem" />
            <i class="fork-rail" />
            <i class="fork-drop left" />
            <i class="fork-drop right" />
          </div>

          <div class="arch-box">
            <div class="arch-box-label">Regional domains</div>
            <div class="arch-domain mono">{p.region.domain}</div>
            {p.serviceIngress.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">{nodeSub(r)}</div>
              </div>
            ))}
          </div>

          <div class="arch-box">
            <div class="arch-box-label">Custom domain targets</div>
            <div class="arch-domains">
              <div class="arch-domain mono">
                {p.region.code}.identity.onetime.co<span class="arch-domain-via">via Approximated</span>
              </div>
              <div class="arch-domain mono">
                {p.region.code}.onetime.co<span class="arch-domain-via">direct · transitioning</span>
              </div>
            </div>
            {p.customIngress.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">{nodeSub(r)}</div>
              </div>
            ))}
            <p class="arch-note">
              Your DNS points at one of these. TLS terminates at Approximated today; we're
              transitioning to certificates we issue directly. Custom-domain traffic is never proxied
              through Cloudflare.
            </p>
          </div>

          <div class="arch-arrow" aria-hidden="true"></div>
          <div class="arch-arrow" aria-hidden="true"></div>
        </div>

        <div class="arch-box hosting">
          <div class="arch-box-label">Hosting &amp; compute — {p.region.label}</div>
          <div class="arch-node-grid">
            {p.hosting.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">
                  {r.short} · {r.location}
                </div>
              </div>
            ))}
          </div>
          <p class="arch-note">
            Secrets are encrypted at rest here, read once, then destroyed. Key material is separated
            from the database tier.
          </p>
        </div>

        <div class="arch-cols three">
          <div class="arch-arrow" aria-hidden="true"></div>
          <div class="arch-arrow" aria-hidden="true"></div>
          <div class="arch-arrow" aria-hidden="true"></div>

          <div class="arch-box">
            <div class="arch-box-label muted">Encrypted backups</div>
            {p.backups.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">{nodeSub(r)}</div>
              </div>
            ))}
            <p class="arch-note">Age out on a fixed 30-day schedule, same jurisdiction.</p>
          </div>

          <div class="arch-box">
            <div class="arch-box-label muted">Email — addresses &amp; notices only</div>
            {p.email.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">{nodeSub(r)}</div>
              </div>
            ))}
          </div>

          <div class="arch-box">
            <div class="arch-box-label muted">Payments — billing only</div>
            {p.payments.map(({ s, r }) => (
              <div class={`arch-node${r.status === "transitioning" ? "" : " always"}`}>
                <div class="arch-node-name">{r.label ?? s.shortName}</div>
                <div class="arch-node-sub">{nodeSub(r)}</div>
              </div>
            ))}
            <p class="arch-note">Never Secret Content.</p>
          </div>
        </div>

        <div class="arch-legend">
          <span>
            <i class="swatch always" />
            Always in use
          </span>
          <span>
            <i class="swatch" />
            In transition · tier noted on the node
          </span>
          <span class="arch-legend-source">
            Rendered from trust.yaml · updated {trust.meta.updatedAt}
          </span>
        </div>
      </div>
    ))
  }
</div>

<script>
  // Static tab switcher: every region's panel is pre-rendered; this only
  // flips `hidden`. With JS off, the noscript rule below shows them all,
  // hides the internet fan-out, and the fork stem falls back to center.
  // Geometry vars live on the root: --tab-x-* mark each tab's horizontal
  // center for the fan-out drops (--tab-x-first/-last bound the rail),
  // and --fork-x tracks the selected tab for every panel's fork stem.
  document.querySelectorAll<HTMLElement>("[data-arch]").forEach((root) => {
    const tabs = root.querySelectorAll<HTMLButtonElement>('[role="tab"]');
    const setArrowGeometry = () => {
      const rootBox = root.getBoundingClientRect();
      const centerPct = (el: Element) => {
        const box = el.getBoundingClientRect();
        return `${((box.left + box.width / 2 - rootBox.left) / rootBox.width) * 100}%`;
      };
      tabs.forEach((tab, i) => root.style.setProperty(`--tab-x-${i}`, centerPct(tab)));
      if (tabs.length > 0) {
        root.style.setProperty("--tab-x-first", centerPct(tabs[0]));
        root.style.setProperty("--tab-x-last", centerPct(tabs[tabs.length - 1]));
      }
      const selected = root.querySelector('[role="tab"][aria-selected="true"]');
      if (selected) root.style.setProperty("--fork-x", centerPct(selected));
    };
    tabs.forEach((tab) =>
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
        root.querySelectorAll<HTMLElement>(".arch-panel").forEach((panel) => {
          panel.hidden = panel.dataset.region !== tab.dataset.region;
        });
        setArrowGeometry();
      }),
    );
    setArrowGeometry();
    window.addEventListener("resize", setArrowGeometry);
  });
</script>

<noscript>
  <style>
    .arch-tabs,
    .arch-branch {
      display: none;
    }
    .arch-panel[hidden] {
      display: block;
    }
    .arch-panel + .arch-panel {
      margin-top: 40px;
    }
  </style>
</noscript>

<style>
  .arch {
    font-family: var(--sans);
  }

  .arch-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin: 4px 0;
  }
  .arch-tabs button {
    font: 600 12.5px var(--sans);
    letter-spacing: 0.04em;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
  }
  .arch-tabs button:hover {
    color: var(--ink);
    border-color: var(--faint);
  }
  .arch-tabs button[aria-selected="true"] {
    border-color: var(--rust);
    color: var(--rust);
  }

  .arch-box {
    border: 1px solid var(--hairline);
    background: var(--panel);
    padding: 14px 16px;
  }
  .arch-box.dashed {
    border-style: dashed;
    background: transparent;
  }
  .arch-box.center {
    text-align: center;
  }
  .arch-box.hosting {
    border-color: var(--rust);
  }

  .arch-box-label {
    font: 600 10.5px var(--sans);
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 4px;
  }
  .arch-box-label.muted {
    color: var(--faint);
  }

  .arch-domain {
    font: 500 12.5px var(--mono);
    color: var(--ink);
    margin: 0 0 10px;
  }
  .arch-domains {
    margin-bottom: 10px;
  }
  .arch-domains .arch-domain {
    margin: 0 0 4px;
  }
  .arch-domains .arch-domain:last-child {
    margin-bottom: 0;
  }
  .arch-domain-via {
    font: 400 10.5px var(--sans);
    color: var(--faint);
    letter-spacing: 0;
    margin-left: 8px;
  }
  .mono {
    font-family: var(--mono);
  }

  .arch-cols {
    display: grid;
    gap: 0 18px;
  }
  .arch-cols.two {
    grid-template-columns: 1fr 1fr;
  }
  .arch-cols.three {
    grid-template-columns: 1fr 1.2fr 1fr;
  }
  /* Connectors are drawn from 1px fills, and arrowheads from 45°-rotated
     1px-border chevrons, so heads and lines carry identical stroke
     weight — the ↓ glyph renders at font weight and visibly mismatches
     the hairlines it joins. Vertical lines sit at calc(x - 0.5px) so the
     1px fill is centered on its coordinate. */
  .branch-stem,
  .branch-rail,
  .branch-drop,
  .fork-stem,
  .fork-rail,
  .fork-drop {
    position: absolute;
    display: block;
    background: var(--faint);
  }
  .branch-drop::after,
  .fork-drop::after,
  .arch-arrow::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 7px;
    height: 7px;
    border-right: 1px solid var(--faint);
    border-bottom: 1px solid var(--faint);
    transform: translateX(-50%) rotate(45deg);
  }

  .arch-arrow {
    position: relative;
    height: 26px;
  }
  .arch-arrow::before {
    content: "";
    position: absolute;
    top: 3px;
    bottom: 5px;
    left: calc(50% - 0.5px);
    width: 1px;
    background: var(--faint);
  }
  .arch-arrow::after {
    bottom: 5px;
  }

  /* Internet fan-out: centered stem, rail spanning the region tab
     centers, one drop per tab (--tab-x-* measured by the tab script). */
  .arch-branch {
    position: relative;
    height: 32px;
  }
  .branch-stem {
    top: 0;
    left: calc(50% - 0.5px);
    width: 1px;
    height: 13px;
  }
  .branch-rail {
    top: 12px;
    height: 1px;
    left: var(--tab-x-first, 50%);
    right: calc(100% - var(--tab-x-last, 50%));
  }
  .branch-drop {
    top: 12px;
    width: 1px;
    height: 18px;
    left: calc(var(--x, 50%) - 0.5px);
  }

  /* Selected-tab fork: stem at --fork-x (clamped to the rail), rail
     between the two column centers (each 25% in, offset half the 18px
     column gap), a drop with an arrowhead onto each ingress path. */
  .arch-fork {
    grid-column: 1 / -1;
    position: relative;
    height: 38px;
  }
  .fork-stem {
    top: 0;
    width: 1px;
    height: 15px;
    left: clamp(calc(25% - 5px), calc(var(--fork-x, 50%) - 0.5px), calc(75% + 4px));
    transition: left 0.25s ease;
  }
  .fork-rail {
    top: 14px;
    height: 1px;
    left: calc(25% - 4.5px);
    right: calc(25% - 4.5px);
  }
  .fork-drop {
    top: 14px;
    width: 1px;
    height: 18px;
  }
  .fork-drop.left {
    left: calc(25% - 5px);
  }
  .fork-drop.right {
    left: calc(75% + 4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .fork-stem {
      transition: none;
    }
  }

  .arch-node {
    border: 1px dashed var(--faint);
    background: var(--paper);
    padding: 8px 11px;
    margin-top: 8px;
  }
  .arch-node.always {
    border: 1px solid var(--rust);
  }
  .arch-node-name {
    font: 600 13.5px var(--sans);
    color: var(--ink);
  }
  .arch-node-sub {
    font: 400 11.5px/1.45 var(--sans);
    color: var(--faint);
    margin-top: 2px;
  }
  .arch-node-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 8px;
  }
  .arch-node-grid .arch-node {
    margin-top: 0;
  }

  .arch-note {
    font: 400 11.5px/1.55 var(--sans);
    color: var(--faint);
    margin: 10px 0 0;
  }

  .arch-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    margin-top: 18px;
    padding-top: 12px;
    border-top: 1px solid var(--hairline);
    font: 400 11.5px var(--sans);
    color: var(--faint);
  }
  .arch-legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .arch-legend-source {
    margin-left: auto;
  }
  .swatch {
    display: inline-block;
    width: 14px;
    height: 10px;
    border: 1px dashed var(--faint);
  }
  .swatch.always {
    border: 1px solid var(--rust);
  }

  @media (max-width: 720px) {
    .arch-cols.two,
    .arch-cols.three {
      grid-template-columns: 1fr;
    }
    /* Stacked columns need only one arrow per connector row. */
    .arch-cols .arch-arrow ~ .arch-arrow {
      display: none;
    }
    /* Columns stack, so the fan-out and the fork each collapse to a
       single centered arrow drawn on the container's own pseudos. */
    .arch-branch,
    .arch-fork {
      height: 26px;
    }
    .arch-branch > *,
    .arch-fork > * {
      display: none;
    }
    .arch-branch::before,
    .arch-fork::before {
      content: "";
      position: absolute;
      top: 3px;
      bottom: 5px;
      left: calc(50% - 0.5px);
      width: 1px;
      background: var(--faint);
    }
    .arch-branch::after,
    .arch-fork::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 5px;
      width: 7px;
      height: 7px;
      border-right: 1px solid var(--faint);
      border-bottom: 1px solid var(--faint);
      transform: translateX(-50%) rotate(45deg);
    }
    .arch-cols .arch-box {
      margin-bottom: 12px;
    }
    .arch-legend-source {
      margin-left: 0;
    }
  }
</style>
